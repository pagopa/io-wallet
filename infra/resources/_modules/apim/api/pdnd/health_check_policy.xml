<policies>
    <inbound>
        <base />
        <rewrite-uri template="/health" />
    </inbound>
    <outbound>
        <base />
        <choose>
            <when condition="@(context.Response.StatusCode == 200)">
                <set-status code="200" reason="OK" />
                <set-body>@{
                    return "{ \"status\": \"healthy\" }";
                }</set-body>
            </when>
        </choose>
    </outbound>
</policies>